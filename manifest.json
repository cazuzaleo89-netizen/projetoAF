{
  "manifest_version": 3,
  "name": "Painel Fiscal — TEC Automator",
  "short_name": "TEC Automator",
  "version": "3.6.0",
  "description": "Rastreia acertos/erros no TecConcursos com SM-2, IRT, edital, biblioteca PDF, heatmap, forgetting curve, smart goal, simulado, export Anki e backup. Funciona também como página web.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "notifications",
    "tabs",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "*://www.tecconcursos.com.br/*",
    "*://cazuzaleo89-netizen.github.io/*",
    "https://api.anthropic.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://www.tecconcursos.com.br/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "*://cazuzaleo89-netizen.github.io/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Painel Fiscal",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lib/pdf.worker.min.js"
      ],
      "matches": [
        "*://www.tecconcursos.com.br/*",
        "*://cazuzaleo89-netizen.github.io/*"
      ]
    }
  ]
}
